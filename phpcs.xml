<ruleset>
  <rule ref="WordPress">
    <exclude name="WordPress.Files.FileName" />
    <exclude name="WordPress.WhiteSpace" />
    <exclude name="WordPress.PHP.YodaConditions" />
    <exclude name="WordPress.Arrays.ArrayDeclarationSpacing" />
    <exclude name="WordPress.NamingConventions" />
    <exclude name="WordPress.Arrays.ArrayIndentation" />
    <exclude name="WordPress.WP.I18n.MissingTranslatorsComment" />
    <exclude name="WordPress.PHP.DontExtract.extract_extract" />
    <exclude name="WordPress.Arrays.ArrayKeySpacingRestrictions.NoSpacesAroundArrayKeys" />
  </rule>
  <rule ref="PSR1">
    <exclude name="PSR1" />
  </rule>
  <rule ref="PSR2">
    <exclude name="PSR2" />
  </rule>
  <rule ref="PSR12">
    <exclude name="PSR12" />
  </rule>
  <rule ref="NormalizedArrays">
    <exclude name="NormalizedArrays" />
  </rule>
  <rule ref="Generic">
    <exclude name="Generic" />
  </rule>
  <rule ref="Squiz">
    <exclude name="Squiz" />
  </rule>
  <rule ref="Zend">
    <exclude name="Zend" />
  </rule>
  <rule ref="Universal">
    <exclude name="Universal.Arrays.DisallowShortArraySyntax" />
    <exclude name="Universal.PHP.RequireExitDieParentheses.Missing" />
    <exclude name="Universal.PHP.DisallowExitDieParentheses.Found" />
    <exclude name="Universal.ControlStructures.IfElseDeclaration.NoNewLine" />
    <exclude name="Universal.Classes.RequireFinalClass.NonFinalClassFound" />
  </rule>
</ruleset>