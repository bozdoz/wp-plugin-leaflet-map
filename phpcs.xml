  <rule ref="PSR1">
    <exclude name="PSR1" />
  </rule>
  <rule ref="PSR2">
    <exclude name="PSR2" />
  </rule>
  <rule ref="PSR12">
    <exclude name="PSR12" />
  </rule>
  <rule ref="NormalizedArrays">
    <exclude name="NormalizedArrays" />
  </rule>
  <rule ref="Generic">
    <exclude name="Generic" />
  </rule>
  <rule ref="Squiz">
    <exclude name="Squiz" />
  </rule>
  <rule ref="Zend">
    <exclude name="Zend" />
  </rule>
